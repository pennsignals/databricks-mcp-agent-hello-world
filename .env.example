# Copy this file to .env for local development.
# Databricks auth should come from:
#   databricks auth login --host https://<your-workspace-url>
# .env is only for non-secret local defaults and the Databricks profile name.
# Do not put DATABRICKS_HOST, DATABRICKS_TOKEN, DATABRICKS_CLIENT_ID,
# or DATABRICKS_CLIENT_SECRET in .env for the supported local quickstart path.

DATABRICKS_CONFIG_PROFILE=DEFAULT
LOG_LEVEL=INFO
