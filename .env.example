# Copy to .env for local overrides and convenience.
# Databricks auth should normally come from CLI profiles for local development.
# workspace-config.yml is the main project config file.
# Use .env for overrides, not as the only config source.

DATABRICKS_CONFIG_PROFILE=DEFAULT
LLM_ENDPOINT_NAME=your-llm-endpoint-name
LOG_LEVEL=INFO

# Optional local overrides used by the current implementation.
ACTIVE_PROFILE_NAME=default
MAX_ALLOWED_TOOLS=4
MAX_AGENT_STEPS=8
