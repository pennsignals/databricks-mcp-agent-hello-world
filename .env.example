# Copy this file to .env for local development.
# Local attended auth should usually live in ~/.databrickscfg after:
#   databricks auth login --profile <profile-name>
#
# Example:
#   cp .env.example .env

# Recommended attended local auth
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Optional compatibility overrides for local testing
# DATABRICKS_HOST=https://<your-workspace>.databricks.com
# DATABRICKS_TOKEN=dapi...

# Core agent settings
LLM_ENDPOINT_NAME=your-llm-endpoint-name
TOOL_PROVIDER_TYPE=local_python
ACTIVE_PROFILE_NAME=default
AUTH_MODE=local-dev
LOG_LEVEL=INFO
MAX_ALLOWED_TOOLS=4
MAX_AGENT_STEPS=8

# Persistence targets
TOOL_PROFILE_TABLE=main.agent_demo.tool_profiles
AGENT_RUNS_TABLE=main.agent_demo.agent_runs
AGENT_OUTPUT_TABLE=main.agent_demo.agent_outputs
LOCAL_DATA_DIR=./.local_state

# Prompt paths
TOOL_FILTER_PROMPT_PATH=./src/databricks_mcp_agent_hello_world/prompts/tool_filter_prompt.txt
TOOL_AUDIT_PROMPT_PATH=./src/databricks_mcp_agent_hello_world/prompts/tool_audit_prompt.txt
AGENT_SYSTEM_PROMPT_PATH=./src/databricks_mcp_agent_hello_world/prompts/agent_system_prompt.txt

# Local tool backend mode:
# - auto: use Databricks SQL when warehouse config is present, otherwise mock data
# - databricks: require Databricks SQL configuration
# - mock: always use local mock data
LOCAL_TOOL_BACKEND_MODE=auto

# Optional Databricks SQL settings for real local tool execution
# DATABRICKS_SQL_WAREHOUSE_ID=
# DATABRICKS_SQL_CATALOG=
# DATABRICKS_SQL_SCHEMA=
# INCIDENT_KB_TABLE=
# RUNBOOK_TABLE=
# CUSTOMER_SUMMARY_TABLE=
# SERVICE_INCIDENTS_TABLE=
# SERVICE_DEPENDENCIES_TABLE=
